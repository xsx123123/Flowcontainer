# ============================================================================
# RNAFlow Environment Template
# 根据conda yaml文件自动生成的容器镜像
# Environment: {{env_name}}
# ============================================================================

FROM mambaorg/micromamba:1.5.10

LABEL maintainer="RNAFlow"
LABEL environment="{{env_name}}"
LABEL generated="true"

USER root

# 安装系统依赖
RUN apt-get update && apt-get install -y --no-install-recommends \
    procps \
    && rm -rf /var/lib/apt/lists/*

# 复制环境文件
COPY {{env_file}} /tmp/environment.yml

# 使用micromamba创建环境（关键修复：使用create而不是install）
RUN micromamba create -y -n {{env_name}} -f /tmp/environment.yml \
    && micromamba clean -afy \
    && rm /tmp/environment.yml

# 设置环境变量 - 确保命令可以直接运行（如 bwa index）
ENV MAMBA_ROOT_PREFIX=/opt/conda
ENV CONDA_DEFAULT_ENV={{env_name}}
ENV CONDA_PREFIX=/opt/conda/envs/{{env_name}}

# 关键：将环境bin目录放在PATH最前面，使命令可直接运行
ENV PATH="/opt/conda/envs/{{env_name}}/bin:/opt/conda/bin:${PATH}"

# 配置shell自动激活环境（对于交互式shell）
RUN echo "micromamba activate {{env_name}}" >> /root/.bashrc && \
    echo "micromamba activate {{env_name}}" >> /root/.profile

# 创建启动脚本，确保非交互式shell也能使用环境
RUN cat > /usr/local/bin/activate_env.sh << 'EOF'
#!/bin/bash
# 自动激活环境的脚本
export PATH="/opt/conda/envs/{{env_name}}/bin:/opt/conda/bin:${PATH}"
export CONDA_DEFAULT_ENV={{env_name}}
export CONDA_PREFIX=/opt/conda/envs/{{env_name}}
exec "$@"
EOF
RUN chmod +x /usr/local/bin/activate_env.sh

# 健康检查 - 检查关键工具
{% if health_check_cmd %}
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD {{health_check_cmd}} || exit 1
{% endif %}

# 使用自定义入口点脚本，确保环境激活
COPY <<'EOF' /usr/local/bin/entrypoint.sh
#!/bin/bash
set -e

# 确保PATH设置正确
export PATH="/opt/conda/envs/{{env_name}}/bin:/opt/conda/bin:${PATH}"
export CONDA_DEFAULT_ENV={{env_name}}
export CONDA_PREFIX=/opt/conda/envs/{{env_name}}

# 如果用户指定了命令，执行命令；否则进入交互式shell
if [ $# -eq 0 ]; then
    echo "RNAFlow Environment: {{env_name}}"
    echo "Type 'exit' to leave the container"
    exec bash --rcfile /root/.bashrc
else
    # 直接执行命令（环境已通过PATH激活）
    exec "$@"
fi
EOF
RUN chmod +x /usr/local/bin/entrypoint.sh

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
CMD ["bash"]
